# Telegram bot sozlamalari — NAMUNA. Nusxa: cp .env.example .env
# Haqiqiy .env git'ga tushmaydi (.gitignore).

# @BotFather bergan token — MAXFIY.
BOT_TOKEN=123456789:CHANGE_ME_BotFather_token

TELEGRAM_CHANNEL=@TayyorPrava
CHANNEL_URL=https://t.me/TayyorPrava
BACKEND_URL=http://127.0.0.1:8000/api

# Backend .env dagi BOT_SHARED_SECRET bilan AYNAN bir xil bo'lishi shart.
BOT_SHARED_SECRET=CHANGE_ME_backend_env_bilan_bir_xil
