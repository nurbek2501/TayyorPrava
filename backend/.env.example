# Backend muhit sozlamalari — NAMUNA.
# Nusxa oling:  cp .env.example .env   (Windows: copy .env.example .env)
# Haqiqiy .env git'ga tushmaydi (.gitignore).

DATABASE_URL=sqlite+aiosqlite:///./app.db
# Production (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost/pravapro

# JWT imzo kaliti — MAJBURIY: kuchli tasodifiy qiymat qo'ying.
# Generatsiya: python -c "import secrets; print(secrets.token_hex(48))"
SECRET_KEY=CHANGE_ME_kuchli_tasodifiy_qiymat_qoying
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

PROJECT_NAME=TayyorPrava
API_PREFIX=/api
UPLOAD_DIR=./uploads

# Ruxsat etilgan brauzer manzillari (vergul bilan).
# Production'da o'z domeningizni qo'shing: https://tayyorprava.uz
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Telegram bot bilan UMUMIY maxfiy kalit — bot .env dagi qiymat bilan AYNAN bir xil bo'lsin.
# Generatsiya: python -c "import secrets; print(secrets.token_urlsafe(32))"
BOT_SHARED_SECRET=CHANGE_ME_bot_env_bilan_bir_xil

# Rate limiting (brute-force himoyasi). Ko'p test akkaunt yaratayotganda dev'da
# vaqtincha False qilish mumkin. Production'da True qoldiring.
RATE_LIMIT_ENABLED=True

# Suiiste'mol/hujum aniqlash -> avtomatik akkaunt bloki (admin ochmaguncha).
# Dev'da agancha bezovta qilsa False qilish mumkin; production'da True.
ABUSE_GUARD_ENABLED=True

# ---- Savol bazasini ko'chirib olishga (scraping) qarshi ----
# Rate-limit stor'i: ko'p worker bo'lsa Redis (yagona hisob), aks holda in-memory.
# REDIS_URL=redis://localhost:6379/0
REDIS_URL=
# Savol endpointlari limiti (foydalanuvchi bo'yicha).
RATE_LIMIT_QUESTIONS=20/minute
# Ochiq (tokensiz) endpointlar limiti (IP bo'yicha): /landing, /tariffs — mehmon bosh sahifasi.
RATE_LIMIT_PUBLIC=30/minute
# So'rov tanasi (body) uchun global maksimal hajm (MB) — juda katta yuk (DoS) 413 bilan rad etiladi.
# Rasm yuklashdan (MAX_UPLOAD_MB=5) yuqori qo'ying.
MAX_REQUEST_MB=8
# Bir so'rovda nechta savol (to'liq mavzu birdaniga emas).
QUESTIONS_PAGE_DEFAULT=10
QUESTIONS_PAGE_MAX=20
# Scraping anomaliyasi: shu oynada (s) shuncha TURLI topic/ticket -> akkaunt bloki.
SCRAPE_DISTINCT_TOPICS=10
SCRAPE_WINDOW_SECONDS=60
# Bepul (obunasiz) foydalanuvchi faqat namuna: topic/bilet 1..N.
DEMO_MAX_TOPIC_ID=2
DEMO_MAX_TICKET=2
# Mashq variantlarini har so'rovda aralashtirish.
SHUFFLE_OPTIONS=True

# MUHIM: production'da DEBUG=False qoldiring — aks holda /docs, /redoc, /openapi.json
# ochiq bo'lib API tuzilmasini oshkor qiladi.
DEBUG=True
